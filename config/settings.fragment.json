{
  "//": "Merged additively into ~/.claude/settings.json by /set-me — never replaces the file. permissions.deny > permissions.ask > permissions.allow in precedence, so an ASK entry overrides a broader ALLOW (e.g. 'dotnet ef' is allowed but 'dotnet ef database' asks).",
  "//autonomy": "ALLOW = the safe local dev loop that runs silently in fire-and-forget mode. ASK = irreversible / destructive / remote-code / publishing operations that always stop for the human even mid-run (per DISPATCH.md §0 hard-gate list). See docs/AUTONOMY-REDESIGN-SPEC.md.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$HOME/.claude/subagent-driven-default.json\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/guard-secrets.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-length-check.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet ef:*)",
      "Bash(dotnet watch:*)",
      "Bash(mkdir:*)",
      "PowerShell(git status:*)",
      "PowerShell(git log:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git show:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git rev-parse:*)",
      "PowerShell(git add:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git checkout:*)",
      "PowerShell(git switch:*)",
      "PowerShell(git merge:*)",
      "PowerShell(git worktree:*)",
      "PowerShell(git fetch:*)",
      "PowerShell(git pull:*)",
      "PowerShell(git stash:*)",
      "PowerShell(dotnet build:*)",
      "PowerShell(dotnet test:*)",
      "PowerShell(dotnet run:*)",
      "PowerShell(dotnet restore:*)",
      "PowerShell(dotnet format:*)",
      "PowerShell(dotnet new:*)",
      "PowerShell(dotnet ef:*)",
      "PowerShell(dotnet watch:*)",
      "PowerShell(New-Item:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(gh:*)",
      "Bash(sqlcmd:*)",
      "Bash(dotnet ef database:*)",
      "Bash(dotnet publish:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(iisreset:*)",
      "Bash(sc:*)",
      "Bash(net stop:*)",
      "Bash(net start:*)",
      "PowerShell(git push:*)",
      "PowerShell(git tag:*)",
      "PowerShell(git reset:*)",
      "PowerShell(git restore:*)",
      "PowerShell(git rebase:*)",
      "PowerShell(git clean:*)",
      "PowerShell(git commit --amend:*)",
      "PowerShell(git filter-branch:*)",
      "PowerShell(gh:*)",
      "PowerShell(sqlcmd:*)",
      "PowerShell(dotnet ef database:*)",
      "PowerShell(dotnet publish:*)",
      "PowerShell(npx:*)",
      "PowerShell(npm:*)",
      "PowerShell(node:*)",
      "PowerShell(python:*)",
      "PowerShell(python3:*)",
      "PowerShell(pip:*)",
      "PowerShell(iisreset:*)",
      "PowerShell(Restart-Service:*)",
      "PowerShell(Stop-Service:*)",
      "PowerShell(Start-Service:*)"
    ]
  }
}
