{
  "//": "Merged additively into ~/.claude/settings.json by /set-me — never replaces the file.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$HOME/.claude/subagent-driven-default.json\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/guard-secrets.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "PowerShell(git status:*)",
      "PowerShell(git log:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git show:*)",
      "PowerShell(git branch:*)",
      "PowerShell(dotnet build:*)",
      "PowerShell(dotnet test:*)"
    ]
  }
}
